using System;
using System.Net;
using System.Net.Mail;
using System.Threading;

public class CPHInline
{
    public bool Execute()
    {
        // Grab the rawInput from the channel point redeem
        // Grab and clean the rawInput
        string smsBody = args.ContainsKey("rawInput") ? ((string)args["rawInput"]).Trim() : null;
        if (string.IsNullOrEmpty(smsBody))
        {
            return true; // silently exit
        }

        // Add a signature stamp with redeemer's name
        string signature = $"\n- Sent by {args["user"]}";
        smsBody += signature;
        // ========================================
        //  ūüõĎ DO NOT SHARE THIS INFO PUBLICLY! ūüõĎ
        // ========================================
        // Your Fi SMS gateway address (replace with your own number)
        string fiGatewayAddress = "YOUR_PHONE_NUMBER@YOUR_CARRIER_GATEWAY";
        // Configure SMTP client (example uses Gmail SMTP)
        SmtpClient client = new SmtpClient("smtp.gmail.com", 587)
        {
            Credentials = new NetworkCredential("YOUR_EMAIL@example.com", "YOUR_APP_PASSWORD"),
            EnableSsl = true
        };
        // Build the email WITHOUT a subject
        MailMessage mail = new MailMessage();
        mail.From = new MailAddress("YOUR_EMAIL@example.com");
        mail.To.Add(fiGatewayAddress);
        mail.Body = smsBody;
        // OPTIONAL: ADD SOUND EFFECT [REMOVE /* TO ACTIVATE IT!]
        try
        {
            client.Send(mail);
            int delayMs = 4000; // 4 seconds
            Thread.Sleep(delayMs);
            CPH.PlaySound(@"C:\PATH\TO\YOUR\SOUND_FILE.mp3", 0.5f);
        // No chat message‚ÄĒsilent success
        }
        catch
        {
        // Silent failure too‚ÄĒno chat output
        }

        return true;
    }
}
